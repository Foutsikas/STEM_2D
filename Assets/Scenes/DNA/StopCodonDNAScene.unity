    - target: {fileID: 8326445925300945356, guid: 41c35a1b8c1346243980e248ec5e5e11, type: 3}
      propertyPath: slides.Array.size
      value: 4
      objectReference: {fileID: 0}
    - target: {fileID: 8326445925300945356, guid: 41c35a1b8c1346243980e248ec5e5e11, type: 3}
      propertyPath: 'slides.Array.data[0]'
      value: "\u03A4\u03B9 \u03B5\u03B9\u03BD\u03B1\u03B9 \u03C4\u03B1 \u03BA\u03C9\u03B4\u03B9\u03BA\u03BF\u03BD\u03B9\u03B1
        \u03BB\u03B7\u03BE\u03B7\u03C2;\n\n\u03A4\u03B1 \u03BA\u03C9\u03B4\u03B9\u03BA\u03BF\u03BD\u03B9\u03B1
        \u03BB\u03B7\u03BE\u03B7\u03C2 \u03C3\u03B7\u03BC\u03B1\u03C4\u03BF\u03B4\u03BF\u03C4\u03BF\u03C5\u03BD
        \u03C4\u03BF \u03C4\u03B5\u03BB\u03BF\u03C2 \u03C4\u03B7\u03C2 \u03BC\u03B5\u03C4\u03B1\u03C6\u03C1\u03B1\u03C3\u03B7\u03C2
        \u03BC\u03B9\u03B1\u03C2 \u03C0\u03C1\u03C9\u03C4\u03B5\u03B9\u03BD\u03B7\u03C2.
        \u039F\u03C4\u03B1\u03BD \u03C4\u03BF \u03C1\u03B9\u03B2\u03BF\u03C3\u03C9\u03BC\u03B1
        \u03C3\u03C5\u03BD\u03B1\u03BD\u03C4\u03B7\u03C3\u03B5\u03B9 \u03B5\u03BD\u03B1
        \u03BA\u03C9\u03B4\u03B9\u03BA\u03BF\u03BD\u03B9\u03BF \u03BB\u03B7\u03BE\u03B7\u03C2,
        \u03C3\u03C4\u03B1\u03BC\u03B1\u03C4\u03B1 \u03C4\u03B7 \u03C3\u03C5\u03BD\u03B8\u03B5\u03C3\u03B7."
      objectReference: {fileID: 0}
    - target: {fileID: 8326445925300945356, guid: 41c35a1b8c1346243980e248ec5e5e11, type: 3}
      propertyPath: 'slides.Array.data[1]'
      value: "\u03A4\u03B1 3 \u03BA\u03C9\u03B4\u03B9\u03BA\u03BF\u03BD\u03B9\u03B1
        \u03BB\u03B7\u03BE\u03B7\u03C2 \u03C3\u03C4\u03BF DNA\n\n\u03A5\u03C0\u03B1\u03C1\u03C7\u03BF\u03C5\u03BD
        \u03C4\u03C1\u03B9\u03B1 \u03BA\u03C9\u03B4\u03B9\u03BA\u03BF\u03BD\u03B9\u03B1
        \u03BB\u03B7\u03BE\u03B7\u03C2:\n- TAA\n- TAG\n- TGA\n\n\u039A\u03B1\u03BD\u03B5\u03BD\u03B1
        \u03B1\u03C0\u03BF \u03B1\u03C5\u03C4\u03B1 \u03B4\u03B5\u03BD \u03BA\u03C9\u03B4\u03B9\u03BA\u03BF\u03C0\u03BF\u03B9\u03B5\u03B9
        \u03B1\u03BC\u03B9\u03BD\u03BF\u03BE\u03C5."
      objectReference: {fileID: 0}
    - target: {fileID: 8326445925300945356, guid: 41c35a1b8c1346243980e248ec5e5e11, type: 3}
      propertyPath: 'slides.Array.data[2]'
      value: "\u0393\u03B9\u03B1\u03C4\u03B9 3 \u03BA\u03C9\u03B4\u03B9\u03BA\u03BF\u03BD\u03B9\u03B1
        \u03BB\u03B7\u03BE\u03B7\u03C2;\n\n\u0397 \u03C5\u03C0\u03B1\u03C1\u03BE\u03B7
        \u03C4\u03C1\u03B9\u03C9\u03BD \u03BA\u03C9\u03B4\u03B9\u03BA\u03BF\u03BD\u03B9\u03C9\u03BD
        \u03BB\u03B7\u03BE\u03B7\u03C2 \u03B5\u03BE\u03B1\u03C3\u03C6\u03B1\u03BB\u03B9\u03B6\u03B5\u03B9
        \u03BF\u03C4\u03B9 \u03B7 \u03BC\u03B5\u03C4\u03B1\u03C6\u03C1\u03B1\u03C3\u03B7
        \u03B8\u03B1 \u03C3\u03C4\u03B1\u03BC\u03B1\u03C4\u03B7\u03C3\u03B5\u03B9
        \u03B1\u03BE\u03B9\u03BF\u03C0\u03B9\u03C3\u03C4\u03B1, \u03B1\u03BA\u03BF\u03BC\u03B1
        \u03BA\u03B9 \u03B1\u03BD \u03BC\u03B9\u03B1 \u03BC\u03B5\u03C4\u03B1\u03BB\u03BB\u03B1\u03BE\u03B7
        \u03B1\u03BB\u03BB\u03B1\u03BE\u03B5\u03B9 \u03B5\u03BD\u03B1 \u03B1\u03C0\u03BF
        \u03B1\u03C5\u03C4\u03B1."
      objectReference: {fileID: 0}
    - target: {fileID: 8326445925300945356, guid: 41c35a1b8c1346243980e248ec5e5e11, type: 3}
      propertyPath: 'slides.Array.data[3]'
      value: "\u03A0\u03B1\u03C1\u03B1\u03BA\u03B1\u03BB\u03C9 \u03C3\u03C5\u03C1\u03B5\u03C4\u03B5
        \u03C4\u03B9\u03C2 \u03B2\u03B1\u03C3\u03B5\u03B9\u03C2 \u03C3\u03C4\u03B7
        \u03C3\u03C9\u03C3\u03C4\u03B7 \u03B8\u03B5\u03C3\u03B7 \u03C9\u03C3\u03C4\u03B5
        \u03BD\u03B1 \u03B4\u03B7\u03BC\u03B9\u03BF\u03C5\u03C1\u03B3\u03B7\u03B8\u03BF\u03C5\u03BD
        \u03C4\u03B1 \u03BA\u03C9\u03B4\u03B9\u03BA\u03BF\u03BD\u03B9\u03B1 \u03BB\u03B7\u03BE\u03B7\u03C2."
      objectReference: {fileID: 0}
    - target: {fileID: 8326445925300945356, guid: 41c35a1b8c1346243980e248ec5e5e11, type: 3}
      propertyPath: 'slides.Array.data[4]'
      value: "\u03A0\u03B1\u03C1\u03B1\u03BA\u03B1\u03BB\u03C9 \u03C3\u03C5\u03C1\u03B5\u03C4\u03B5
        \u03C4\u03B9\u03C2 \u03B2\u03B1\u03C3\u03B5\u03B9\u03C2 \u03C3\u03C4\u03B7
        \u03C3\u03C9\u03C3\u03C4\u03B7 \u03B8\u03B5\u03C3\u03B7 \u03C9\u03C3\u03C4\u03B5
        \u03BD\u03B1 \u03B4\u03B7\u03BC\u03B9\u03BF\u03C5\u03C1\u03B3\u03B7\u03B8\u03B5\u03B9
        \u03C4\u03BF \u03BA\u03C9\u03B4\u03B9\u03BA\u03BF\u03BD\u03B9\u03BF \u03B5\u03BD\u03B1\u03C1\u03BE\u03B7\u03C2."
      objectReference: {fileID: 0}
