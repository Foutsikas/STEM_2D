    - target: {fileID: 8326445925300945356, guid: 41c35a1b8c1346243980e248ec5e5e11, type: 3}
      propertyPath: slides.Array.size
      value: 4
      objectReference: {fileID: 0}
    - target: {fileID: 8326445925300945356, guid: 41c35a1b8c1346243980e248ec5e5e11, type: 3}
      propertyPath: 'slides.Array.data[0]'
      value: "\u03A4\u03B9 \u03B5\u03B9\u03BD\u03B1\u03B9 \u03B5\u03BD\u03B1 \u03BA\u03C9\u03B4\u03B9\u03BA\u03BF\u03BD\u03B9\u03BF;\n\n\u0395\u03BD\u03B1
        \u03BA\u03C9\u03B4\u03B9\u03BA\u03BF\u03BD\u03B9\u03BF \u03B5\u03B9\u03BD\u03B1\u03B9
        \u03BC\u03B9\u03B1 \u03BF\u03BC\u03B1\u03B4\u03B1 \u03C4\u03C1\u03B9\u03C9\u03BD
        \u03B4\u03B9\u03B1\u03B4\u03BF\u03C7\u03B9\u03BA\u03C9\u03BD \u03BD\u03BF\u03C5\u03BA\u03BB\u03B5\u03BF\u03C4\u03B9\u03B4\u03B9\u03C9\u03BD
        \u03C3\u03C4\u03BF DNA \u03B7 \u03C3\u03C4\u03BF RNA. \u039A\u03B1\u03B8\u03B5
        \u03BA\u03C9\u03B4\u03B9\u03BA\u03BF\u03BD\u03B9\u03BF \u03BA\u03C9\u03B4\u03B9\u03BA\u03BF\u03C0\u03BF\u03B9\u03B5\u03B9
        \u03B5\u03BD\u03B1 \u03C3\u03C5\u03B3\u03BA\u03B5\u03BA\u03C1\u03B9\u03BC\u03B5\u03BD\u03BF
        \u03B1\u03BC\u03B9\u03BD\u03BF\u03BE\u03C5."
      objectReference: {fileID: 0}
    - target: {fileID: 8326445925300945356, guid: 41c35a1b8c1346243980e248ec5e5e11, type: 3}
      propertyPath: 'slides.Array.data[1]'
      value: "\u03A0\u03BF\u03C3\u03B1 \u03BA\u03C9\u03B4\u03B9\u03BA\u03BF\u03BD\u03B9\u03B1
        \u03C5\u03C0\u03B1\u03C1\u03C7\u03BF\u03C5\u03BD;\n\n\u039C\u03B5 4 \u03B2\u03B1\u03C3\u03B5\u03B9\u03C2
        \u03BA\u03B1\u03B9 \u03BF\u03BC\u03B1\u03B4\u03B5\u03C2 \u03C4\u03C9\u03BD
        3, \u03C5\u03C0\u03B1\u03C1\u03C7\u03BF\u03C5\u03BD 4 x 4 x 4 = 64 \u03C0\u03B9\u03B8\u03B1\u03BD\u03BF\u03B9
        \u03C3\u03C5\u03BD\u03B4\u03C5\u03B1\u03C3\u03BC\u03BF\u03B9. \u0391\u03C0\u03BF
        \u03B1\u03C5\u03C4\u03BF\u03C5\u03C2:\n- 61 \u03BA\u03C9\u03B4\u03B9\u03BA\u03BF\u03C0\u03BF\u03B9\u03BF\u03C5\u03BD
        \u03B1\u03BC\u03B9\u03BD\u03BF\u03BE\u03B5\u03B1\n- 3 \u03B5\u03B9\u03BD\u03B1\u03B9
        \u03BA\u03C9\u03B4\u03B9\u03BA\u03BF\u03BD\u03B9\u03B1 \u03BB\u03B7\u03BE\u03B7\u03C2
        (STOP)"
      objectReference: {fileID: 0}
    - target: {fileID: 8326445925300945356, guid: 41c35a1b8c1346243980e248ec5e5e11, type: 3}
      propertyPath: 'slides.Array.data[2]'
      value: "\u039F \u03B3\u03B5\u03BD\u03B5\u03C4\u03B9\u03BA\u03BF\u03C2 \u03BA\u03C9\u03B4\u03B9\u03BA\u03B1\u03C2\n\n\u039F
