      propertyPath: 'slides.Array.data[0]'
      value: "\u0391\u03BC\u03B9\u03BD\u03BF\u03BE\u03AD\u03B1\n\n\u03A4\u03B1 \u03B1\u03BC\u03B9\u03BD\u03BF\u03BE\u03AD\u03B1
        \u03B5\u03AF\u03BD\u03B1\u03B9 \u03C4\u03B1 \u03B4\u03BF\u03BC\u03B9\u03BA\u03AC
        \u03C3\u03C4\u03BF\u03B9\u03C7\u03B5\u03AF\u03B1 \u03C4\u03C9\u03BD \u03C0\u03C1\u03C9\u03C4\u03B5\u03CA\u03BD\u03CE\u03BD.\n\u03A5\u03C0\u03AC\u03C1\u03C7\u03BF\u03C5\u03BD
        20 \u03B2\u03B1\u03C3\u03B9\u03BA\u03AC \u03B1\u03BC\u03B9\u03BD\u03BF\u03BE\u03AD\u03B1
        \u03C0\u03BF\u03C5 \u03BA\u03C9\u03B4\u03B9\u03BA\u03BF\u03C0\u03BF\u03B9\u03BF\u03CD\u03BD\u03C4\u03B1\u03B9\n\u03B1\u03C0\u03CC
        \u03C4\u03BF\u03BD \u03B3\u03B5\u03BD\u03B5\u03C4\u03B9\u03BA\u03CC \u03BA\u03CE\u03B4\u03B9\u03BA\u03B1.
        \u039A\u03AC\u03B8\u03B5 \u03B1\u03BC\u03B9\u03BD\u03BF\u03BE\u03CD \u03AD\u03C7\u03B5\u03B9
        \u03BC\u03B9\u03B1\n\u03BC\u03BF\u03BD\u03B1\u03B4\u03B9\u03BA\u03AE \u03C7\u03B7\u03BC\u03B9\u03BA\u03AE
        \u03B4\u03BF\u03BC\u03AE."
      objectReference: {fileID: 0}
    - target: {fileID: 8326445925300945356, guid: 41c35a1b8c1346243980e248ec5e5e11, type: 3}
      propertyPath: 'slides.Array.data[1]'
      value: "\u0391\u03BD\u03B1\u03B3\u03BD\u03CE\u03C1\u03B9\u03C3\u03B7 \u03B1\u03BC\u03B9\u03BD\u03BF\u03BE\u03AD\u03C9\u03BD\n\n\u03A3\u03B5
        \u03B1\u03C5\u03C4\u03AE \u03C4\u03B7 \u03B4\u03C1\u03B1\u03C3\u03C4\u03B7\u03C1\u03B9\u03CC\u03C4\u03B7\u03C4\u03B1
        \u03B8\u03B1 \u03B4\u03B5\u03AF\u03C4\u03B5 \u03C4\u03B7 \u03C7\u03B7\u03BC\u03B9\u03BA\u03AE
        \u03B4\u03BF\u03BC\u03AE\n5 \u03B1\u03BC\u03B9\u03BD\u03BF\u03BE\u03AD\u03C9\u03BD.
        \u0393\u03B9\u03B1 \u03BA\u03B1\u03B8\u03AD\u03BD\u03B1, \u03B5\u03C0\u03B9\u03BB\u03AD\u03BE\u03C4\u03B5
        \u03C4\u03BF \u03C3\u03C9\u03C3\u03C4\u03CC \u03CC\u03BD\u03BF\u03BC\u03B1\n\u03B1\u03C0\u03CC
