  instruction: "\u0392\u03AE\u03BC\u03B1 1: \u03A3\u03C5\u03BD\u03B1\u03C1\u03BC\u03BF\u03BB\u03CC\u03B3\u03B7\u03C3\u03B5
    \u03C4\u03BF \u03BA\u03CD\u03BA\u03BB\u03C9\u03BC\u03B1 \u03BC\u03B5 \u03C4\u03B7\u03BD
    \u03B1\u03BD\u03C4\u03AF\u03C3\u03C4\u03B1\u03C3\u03B7 R2.\n\u03A4\u03BF \u03B1\u03BC\u03C0\u03B5\u03C1\u03CC\u03BC\u03B5\u03C4\u03C1\u03BF
    (RS102) \u03B5\u03AF\u03BD\u03B1\u03B9 \u03AE\u03B4\u03B7 \u03C3\u03C5\u03BD\u03B4\u03B5\u03B4\u03B5\u03BC\u03AD\u03BD\u03BF
    \u03C3\u03B5 \u03C3\u03B5\u03B9\u03C1\u03AC.\n\u03A3\u03CD\u03BD\u03B4\u03B5\u03C3\u03B5
    \u03C4\u03BF \u03B2\u03BF\u03BB\u03C4\u03CC\u03BC\u03B5\u03C4\u03C1\u03BF (RS101)
    \u03C0\u03B1\u03C1\u03AC\u03BB\u03BB\u03B7\u03BB\u03B1 \u03C3\u03C4\u03B1 \u03AC\u03BA\u03C1\u03B1
    \u03C4\u03B7\u03C2 R2.\n\u039A\u03BB\u03B5\u03AF\u03C3\u03B5 \u03C4\u03BF\u03BD
    \u03B4\u03B9\u03B1\u03BA\u03CC\u03C0\u03C4\u03B7 \u03BA\u03B1\u03B9 \u03C0\u03AC\u03C4\u03B7\u03C3\u03B5
    Start (F6)."
  resultText: "\u039C\u03AD\u03C4\u03C1\u03B7\u03C3\u03B7: V = {V} V, I = {I} A\n\n\u039D\u03CC\u03BC\u03BF\u03C2
    \u03C4\u03BF\u03C5 Ohm:\nR2 = V / I = {R} \u03A9\n\n\u0397 \u03B1\u03BD\u03C4\u03AF\u03C3\u03C4\u03B1\u03C3\u03B7
    \u03C4\u03C9\u03BD \u03BA\u03B1\u03BB\u03C9\u03B4\u03AF\u03C9\u03BD \u03B8\u03B5\u03C9\u03C1\u03B5\u03AF\u03C4\u03B1\u03B9
    \u03B1\u03BC\u03B5\u03BB\u03B7\u03C4\u03AD\u03B1."
