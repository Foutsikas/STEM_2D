  m_Name: Phase3_Parallel
  m_EditorClassIdentifier: Assembly-CSharp::STEM.Experiments.Resistance.ResistancePhase
  instruction: "\u0392\u03AE\u03BC\u03B1 3: \u0391\u03BD\u03B1\u03B4\u03B9\u03AC\u03C4\u03B1\u03BE\u03B5
    \u03C4\u03B1 \u03BA\u03B1\u03BB\u03CE\u03B4\u03B9\u03B1 \u03CE\u03C3\u03C4\u03B5
    \u03B7 R1 \u03BD\u03B1 \u03C3\u03C5\u03BD\u03B4\u03B5\u03B8\u03B5\u03AF\n\u03C0\u03B1\u03C1\u03AC\u03BB\u03BB\u03B7\u03BB\u03B1
    \u03BC\u03B5 \u03C4\u03B7\u03BD R2. \u03A4\u03BF \u03B2\u03BF\u03BB\u03C4\u03CC\u03BC\u03B5\u03C4\u03C1\u03BF
    \u03BC\u03B5\u03C4\u03C1\u03AC \u03C4\u03B7\u03BD \u03C4\u03AC\u03C3\u03B7\n\u03C3\u03C4\u03B1
    \u03AC\u03BA\u03C1\u03B1 \u03C4\u03B7\u03C2 R1."
  resultText: "\u039C\u03AD\u03C4\u03C1\u03B7\u03C3\u03B7: V = {V} V, I = {I} A\n\n\u039F\u03BB\u03B9\u03BA\u03AE
    \u03B1\u03BD\u03C4\u03AF\u03C3\u03C4\u03B1\u03C3\u03B7: R\u03BF\u03BB = V / I
    = {R} \u03A9\n\n1/R = 1/R1 + 1/R2 = 1/100 + 1/50  ->  R = 33.33 \u03A9\n\n\u0397
    \u03BF\u03BB\u03B9\u03BA\u03AE \u03B1\u03BD\u03C4\u03AF\u03C3\u03C4\u03B1\u03C3\u03B7
    \u03B5\u03AF\u03BD\u03B1\u03B9 \u03BC\u03B9\u03BA\u03C1\u03CC\u03C4\u03B5\u03C1\u03B7
    \u03B1\u03C0\u03CC \u03BA\u03AC\u03B8\u03B5 \u03B5\u03C0\u03B9\u03BC\u03AD\u03C1\u03BF\u03C5\u03C2\n\u03B1\u03BD\u03C4\u03AF\u03C3\u03C4\u03B1\u03C3\u03B7,
    \u03B3\u03B9\u03B1\u03C4\u03AF \u03C4\u03BF \u03C1\u03B5\u03CD\u03BC\u03B1 \u03AD\u03C7\u03B5\u03B9
    \u03C0\u03B5\u03C1\u03B9\u03C3\u03C3\u03CC\u03C4\u03B5\u03C1\u03BF\u03C5\u03C2
    \u03B4\u03C1\u03CC\u03BC\u03BF\u03C5\u03C2\n\u03BD\u03B1 \u03B1\u03BA\u03BF\u03BB\u03BF\u03C5\u03B8\u03AE\u03C3\u03B5\u03B9."
